{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "No Bloat PDF",
  "version": "1.3.0",
  "identifier": "com.briangalvan.nobloatpdf",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "No Bloat PDF",
        "url": "web/viewer.html",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "worker-src": "'self' blob:",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' blob: data: asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost blob: data: asset: http://asset.localhost",
        "font-src": "'self' data:",
        "media-src": "blob:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF Document",
        "mimeType": "application/pdf",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "windows": {
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "c:\\Users\\18134\\Desktop\\Antigravity\\No Bloat\\src-tauri\\signing\\sign.ps1",
          "%1"
        ]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "installerHooks": "./windows/hooks.nsi"
      }
    },
    "resources": ["pdf-document.ico"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
